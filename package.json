{
  "name": "renderpilot",
  "version": "1.0.0",
  "description": "The Intelligent React (JS/TSX) Performance Analysis CLI — detects anti-patterns, generates interactive HTML reports, and provides pragmatic fixes.",
  "keywords": [
    "react",
    "performance",
    "cli",
    "static-analysis",
    "ast",
    "jsx",
    "tsx",
    "react-performance",
    "code-analysis",
    "developer-tools"
  ],
  "author": "RenderPilot Contributors",
  "license": "MIT",
  "homepage": "https://github.com/ADITYA-user18/renderpilot#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ADITYA-user18/renderpilot.git"
  },
  "bugs": {
    "url": "https://github.com/ADITYA-user18/renderpilot/issues"
  },
  "main": "./src/index.js",
  "bin": {
    "renderpilot": "./src/cli/index.js"
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/cli/index.js",
    "dev": "node src/cli/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "open": "^8.4.2",
    "ora": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "prettier": "^3.3.2"
  },
  "type": "commonjs"
}
